{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabledManagers": ["custom.regex"],
  "customManagers": [
    {
      "description": "Container image field in Kubernetes pod specs inside Coder templates",
      "customType": "regex",
      "managerFilePatterns": ["/^coder/templates/.+\\.tf$/"],
      "matchStrings": [
        "\\s+image\\s*=\\s*\"(?<depName>[a-zA-Z0-9./_-]+):(?<currentValue>[a-zA-Z0-9._-]+)\""
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "description": "CODER_INNER_IMAGE env var value in envbox templates",
      "customType": "regex",
      "managerFilePatterns": ["/^coder/templates/.+\\.tf$/"],
      "matchStrings": [
        "CODER_INNER_IMAGE\"[\\s\\S]{0,80}?value\\s*=\\s*\"(?<depName>[a-zA-Z0-9./_-]+):(?<currentValue>[a-zA-Z0-9._-]+)\""
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "description": "coder_parameter default values containing Docker images (fallback_image, devcontainer_builder, etc.)",
      "customType": "regex",
      "managerFilePatterns": ["/^coder/templates/.+\\.tf$/"],
      "matchStrings": [
        "\\s+default\\s*=\\s*\"(?<depName>[a-zA-Z0-9][a-zA-Z0-9._-]*\\/[a-zA-Z0-9._/-]+):(?<currentValue>[a-zA-Z0-9._-]+)\""
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "description": "Automerge Docker image updates via GitHub native automerge (compatible with branch protection)",
      "matchManagers": ["custom.regex"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true,
      "automergeStrategy": "squash",
      "commitMessagePrefix": "chore(deps): "
    },
    {
      "description": "codercom enterprise images use ubuntu-YYYYMMDD tags - parse as calendar versioning",
      "matchPackageNames": [
        "codercom/enterprise-base",
        "codercom/enterprise-node",
        "codercom/enterprise-desktop"
      ],
      "versioning": "regex:^ubuntu-(?<major>\\d{4})(?<minor>\\d{2})(?<patch>\\d{2})$"
    }
  ]
}
