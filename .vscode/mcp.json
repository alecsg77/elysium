{
	"inputs": [
		{
			"id": "CONTEXT7_API_KEY",
			"type": "promptString",
			"description": "API key for authentication",
			"password": true
		}
	],
	"servers": {
		"kubernetes": {
			"command": "npx",
			"args": [
				"-y",
				"kubernetes-mcp-server@latest"
			],
			"type": "stdio"
		},
		"flux-operator-mcp": {
			"command": "/usr/local/bin/flux-operator-mcp",
			"args": [
				"serve"
			],
			"env": {
				"KUBECONFIG": "${workspaceFolder}/etc/kubeconfig"
			},
			"type": "stdio"
		},
		"grafana": {
			"url": "http://grafana-mcp.monitoring.svc:8000/mcp",
			"type": "http"
		},
		"io.github.upstash/context7": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@upstash/context7-mcp@1.0.31"
			],
			"env": {
				"CONTEXT7_API_KEY": "${input:CONTEXT7_API_KEY}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.31"
		}
	}
}